# =============================================================================
# The Silver Beadle — environment variables
# Copy this file to .env.local for local dev. Add the same keys in Vercel
# Project Settings → Environment Variables for production.
# =============================================================================

# --- Square ---
# Get from Square Developer Dashboard → your app → Credentials.
# Use a SANDBOX token while building/testing — flip to PRODUCTION when ready.
SQUARE_ACCESS_TOKEN=
# "sandbox" or "production". Site falls back to hardcoded products if unset.
SQUARE_ENVIRONMENT=sandbox
# Your Square location ID — Locations API or Dashboard → Account & Settings.
SQUARE_LOCATION_ID=

# --- Square Webhook (set when we wire checkout in commit 2) ---
# Square Developer Dashboard → your app → Webhooks → Signature Key.
SQUARE_WEBHOOK_SIGNATURE_KEY=

# --- Square Web Payments SDK (client-side; safe to expose) ---
# This is the Application ID (NOT the access token) from your Square app.
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=

# --- Auth (commit 3) ---
# Auth.js requires a random secret. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Google OAuth — Google Cloud Console → APIs & Services → Credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Comma-separated emails allowed into /admin (just yours initially).
ADMIN_EMAILS=thesilverbeadle@gmail.com
